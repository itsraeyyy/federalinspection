generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. Better Auth Core
// ==========================================
model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  
  sessions        Session[]
  accounts        Account[]
  userRoles       UserRole[]
  auditLogs       AuditLog[]
  fileVersions    FileVersion[]
  qrLinks         QrLink[]
  notifications   Notification[]
  newsArticles    News[]

  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("accounts")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification_tokens")
}

// ==========================================
// 2. Custom RBAC (Authorization)
// ==========================================
model Role {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "Super Admin", "Content Editor"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  action      String   @unique // e.g., "news.create", "file.upload"
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ==========================================
// 3. File Management System (MinIO linked)
// ==========================================
model FileCategory {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique // e.g., ADMIN_DEFINED, 14
  description String?

  folders Folder[]

  @@map("file_categories")
}

model Folder {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  category   FileCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  files File[]

  @@map("folders")
}

model File {
  id          String   @id @default(cuid())
  title       String
  description String?
  folderId    String
  visibility  String   @default("Internal") // Public, Internal, Restricted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  folder   Folder        @relation(fields: [folderId], references: [id], onDelete: Cascade)
  versions FileVersion[]

  @@map("files")
}

model FileVersion {
  id          String   @id @default(cuid())
  fileId      String
  version     Int      @default(1)
  filename    String
  size        Int
  mimeType    String
  storagePath String   // MinIO object path
  uploadedBy  String
  createdAt   DateTime @default(now())

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user User @relation(fields: [uploadedBy], references: [id])

  @@map("file_versions")
}

// ==========================================
// 4. Audit Logs
// ==========================================
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // e.g., "FILE_DELETED"
  resource   String   // e.g., "File"
  resourceId String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// ==========================================
// 5. QR Approval Workflow
// ==========================================
model QrLink {
  id          String   @id @default(cuid())
  resource    String   // e.g., "File"
  resourceId  String
  createdBy   String
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  creator  User            @relation(fields: [createdBy], references: [id])
  requests AccessRequest[]

  @@map("qr_links")
}

model AccessRequest {
  id           String   @id @default(cuid())
  qrLinkId     String
  deviceInfo   String?
  ipAddress    String?
  status       String   @default("Pending") // Pending, Approved, Denied
  approvedTill DateTime?
  createdAt    DateTime @default(now())

  qrLink QrLink @relation(fields: [qrLinkId], references: [id], onDelete: Cascade)

  @@map("access_requests")
}

// ==========================================
// 6. Notifications
// ==========================================
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // e.g., "NEW_COMPLAINT"
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ==========================================
// 7. News CMS
// ==========================================
model News {
  id          String   @id @default(cuid())
  authorId    String
  status      String   @default("Draft") // Draft, Published
  categoryId  String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author       User              @relation(fields: [authorId], references: [id])
  translations NewsTranslation[]
  media        NewsMedia[]

  @@map("news")
}

model NewsTranslation {
  id       String @id @default(cuid())
  newsId   String
  language String // en, am, or, so, ti, af
  title    String
  content  String

  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@unique([newsId, language])
  @@map("news_translations")
}

model NewsMedia {
  id          String @id @default(cuid())
  newsId      String
  type        String // IMAGE, VIDEO, YOUTUBE
  url         String
  storagePath String?

  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@map("news_media")
}

// ==========================================
// 8. Personnel Module
// ==========================================
model MemberCategory {
  id          String   @id @default(cuid())
  name        String   // e.g., "Main Office", "Branch Office"
  createdAt   DateTime @default(now())

  positions MemberPosition[]

  @@map("member_categories")
}

model MemberPosition {
  id         String   @id @default(cuid())
  title      String   // e.g., "Chief Commissioner"
  categoryId String

  category MemberCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  members  Member[]

  @@map("member_positions")
}

model Member {
  id         String   @id @default(cuid())
  positionId String
  name       String
  email      String?
  phone      String?
  department String?
  photoUrl   String?
  status     String   @default("Active") // Active, Inactive, OnLeave

  position MemberPosition @relation(fields: [positionId], references: [id], onDelete: Restrict)

  @@map("members")
}

// ==========================================
// 9. Complaints & Suggestions
// ==========================================
model Submission {
  id        String   @id @default(cuid())
  type      String   // Complaint, Suggestion
  name      String
  email     String?
  phone     String
  subject   String
  message   String
  status    String   @default("New") // New, Under Review, Resolved, Rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments   SubmissionAttachment[]
  statusHistory SubmissionStatusHistory[]

  @@map("submissions")
}

model SubmissionAttachment {
  id           String @id @default(cuid())
  submissionId String
  filename     String
  storagePath  String

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("submission_attachments")
}

model SubmissionStatusHistory {
  id           String   @id @default(cuid())
  submissionId String
  oldStatus    String?
  newStatus    String
  changedBy    String?  // null if system
  createdAt    DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("submission_status_history")
}
